<Page
    x:Class="Fluency.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fluency">
    <ScrollViewer>
        <Grid RowSpacing="16" Padding="0,0,12,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Header -->
            <StackPanel Spacing="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE779;" FontSize="28" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="Dashboard" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="SystemTimeBlock" Text="" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <!-- Quick Stats - System Information -->
            <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind QuickStats}">
                <ItemsRepeater.Layout>
			<UniformGridLayout ItemsStretch="Fill" MinItemWidth="250" MinItemHeight="110" MinRowSpacing="12" MinColumnSpacing="12" Orientation="Horizontal"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:SystemStatItem">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind Icon}" FontSize="16" Foreground="{x:Bind IconColor}"/>
                                    <TextBlock Text="{x:Bind Label}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{x:Bind Value}" Style="{ThemeResource SubtitleTextBlockStyle}" TextTrimming="WordEllipsis"/>
                                <TextBlock Grid.Row="2" Text="{x:Bind Details}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            <!-- Performance Metrics Cards -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <!-- CPU Usage -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE947;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="CPU Usage" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" x:Name="CpuPercentage" Text="0%" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <ProgressBar Grid.Row="2" x:Name="CpuProgressBar" Value="0" Maximum="100" Margin="0,8,0,8" Height="6" CornerRadius="3"/>
                        <TextBlock Grid.Row="3" x:Name="CpuDetails" Text="Threads: 0" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </Border>
                <!-- RAM Usage -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Grid.Column="1">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEA3C;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="RAM Usage" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" x:Name="RamPercentage" Text="0%" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <ProgressBar Grid.Row="2" x:Name="RamProgressBar" Value="0" Maximum="100" Margin="0,8,0,8" Height="6" CornerRadius="3"/>
                        <TextBlock Grid.Row="3" x:Name="RamDetails" Text="0 GB / 0 GB" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </Border>
                <!-- Disk Usage -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Grid.Column="2">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74C;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Disk Usage" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" x:Name="DiskPercentage" Text="0%" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <ProgressBar Grid.Row="2" x:Name="DiskProgressBar" Value="0" Maximum="100" Margin="0,8,0,8" Height="6" CornerRadius="3"/>
                        <TextBlock Grid.Row="3" x:Name="DiskDetails" Text="0 GB / 0 GB" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>
            <!-- System Health and Quick Actions -->
            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                <!-- System Health Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7FC;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="System Health" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <FontIcon Glyph="&#xEBAC;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Battery" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="BatteryHealthText" Text="N/A" Style="{ThemeResource CaptionTextBlockStyle}" Width="40"/>
                            </Grid>
                            <ProgressBar x:Name="BatteryHealthBar" Value="0" Maximum="100" Height="4" CornerRadius="2"/>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="SecurityStatus" Text="Checking..." Style="{ThemeResource CaptionTextBlockStyle}"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <FontIcon Glyph="&#xE704;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="NetworkStatus" Text="Checking..." Style="{ThemeResource CaptionTextBlockStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Quick Actions -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Grid.Column="1">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE81B;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Quick Actions" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind QuickActions}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8" Orientation="Vertical"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:QuickActionItem">
                                    <Button Content="{x:Bind Label}" Click="QuickActionButton_Click" Tag="{x:Bind Action}" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </Border>
            </Grid>
            <!-- Recent Activities Log -->
            <Border Grid.Row="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Margin="0,8,0,0">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE81C;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Recent Activities" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                    <ListView Grid.Row="1" x:Name="ActivityLog" ItemsSource="{x:Bind RecentActivities}" SelectionMode="None" IsItemClickEnabled="False" MinHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ActivityLogItem">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="8">
                                    <FontIcon Grid.Column="0" Glyph="{x:Bind Icon}" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Message}" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind Timestamp}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Status}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{x:Bind StatusColor}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
