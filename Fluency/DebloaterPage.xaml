<Page
    x:Class="Fluency.DebloaterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fluency">
    <ScrollViewer>
        <Grid RowSpacing="16" Padding="0,0,12,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Spacing="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE74D;" FontSize="28" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="Debloater" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Remove bloatware and optimize your system performance" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Action Buttons -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Button Content="Remove Bloatware" Click="RemoveBloatware_Click" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1" Content="Remove OneDrive" Click="RemoveOneDrive_Click" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="2" Content="Optimize System" Click="OptimizeSystem_Click" HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Info Cards -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                <!-- Bloatware Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Pre-installed Bloatware" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Apps to Remove" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ItemsRepeater Grid.Row="2" ItemsSource="{x:Bind BloatwareApps}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" Orientation="Vertical"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="4">
                                        <FontIcon Glyph="&#xEA39;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </Border>

                <!-- Optimization Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Grid.Column="1">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71E;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Optimization Options" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Available Actions" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Row="2" Spacing="8">
                            <CheckBox Content="Disable Telemetry" IsChecked="False"/>
                            <CheckBox Content="Remove Cortana" IsChecked="False"/>
                            <CheckBox Content="Disable Ads" IsChecked="False"/>
                            <CheckBox Content="Disable Suggestions" IsChecked="False"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Messages -->
            <Border Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Margin="0,8,0,0">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE897;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Operation Log" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                    <ProgressBar Grid.Row="1" x:Name="OperationProgress" Value="0" Maximum="100" Margin="0,4,0,4" Visibility="Collapsed"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollMode="Auto" MaxHeight="200">
                        <TextBlock x:Name="OperationLog" Text="Ready to debloat your system. Click any action button to begin." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
