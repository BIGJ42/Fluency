<Page
    x:Class="Fluent_Terminal.DiskAnalyzerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Fluent_Terminal"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="12,0,12,16" RowSpacing="16">
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE74C;" FontSize="28" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="Disk Analyzer" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Analyze your disk usage and find large files or folders." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="16">
            <!-- Scan Controls -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Select Directory" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox x:Name="PathBox" Text="C:\" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Browse" Click="Browse_Click"/>
                    </Grid>
                    <Button Content="Start Scan" Click="StartScan_Click" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                    
                    <ProgressBar x:Name="ScanProgress" IsIndeterminate="True" Visibility="Collapsed"/>
                    <TextBlock x:Name="StatusText" Text="Select a folder to begin scanning." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Large Folders" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <ListView Grid.Row="1" x:Name="FolderList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:FolderSizeItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="4">
                                    <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind SizeFormatted}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
