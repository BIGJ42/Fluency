<Window
    x:Class="Fluent_Terminal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fluency - Windows 11 Management Center">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*">
        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="24,12">
            <TextBlock Text="Fluency - Windows 11 Management Center" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
        </Border>

        <!-- Navigation and Content -->
        <NavigationView Grid.Row="1"
                        x:Name="NavView" 
                        PaneDisplayMode="Left" 
                        ItemInvoked="NavView_ItemInvoked"
                        IsSettingsVisible="True"
                        IsBackButtonVisible="Collapsed"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        OpenPaneLength="260"
                        CompactModeThresholdWidth="0"
                        IsPaneOpen="True">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE779;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Terminal" Tag="terminal">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="WSL Manager" Tag="wsl">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xECAA;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Maintenance" Tag="maintenance">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Disk Analyzer" Tag="disk">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator Margin="8,8"/>
                <NavigationViewItem Content="Debloater" Tag="debloater">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74D;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Startup Apps" Tag="startup">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71C;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="System Tweaks" Tag="tweaks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontSize="20"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Padding="20"/>
        </NavigationView>
    </Grid>
</Window>