<Page
    x:Class="Fluent_Terminal.MaintenancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="12,0,12,0">
        <StackPanel Spacing="24">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE90F;" FontSize="28" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="Maintenance" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Common system maintenance tasks to keep Windows running smoothly." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <!-- System Cleanup -->
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="🧹 System Cleanup" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        
                        <Button HorizontalAlignment="Stretch" Padding="12" Click="CleanupTempFiles_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                <StackPanel>
                                    <TextBlock Text="Cleanup Temporary Files" FontWeight="SemiBold"/>
                                    <TextBlock Text="Remove temp files, cache, and log files" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Button HorizontalAlignment="Stretch" Padding="12" Click="FlushDNS_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE961;" FontSize="16"/>
                                <StackPanel>
                                    <TextBlock Text="Flush DNS Cache" FontWeight="SemiBold"/>
                                    <TextBlock Text="Clear DNS resolver cache to fix connection issues" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Interface Repair -->
                <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="🛠️ Interface Repair" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                        <Button HorizontalAlignment="Stretch" Padding="12" Click="RestartExplorer_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                                <StackPanel>
                                    <TextBlock Text="Restart Windows Explorer" FontWeight="SemiBold"/>
                                    <TextBlock Text="Fix UI glitches or taskbar issues" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Button HorizontalAlignment="Stretch" Padding="12" Click="RebuildIconCache_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE8B9;" FontSize="16"/>
                                <StackPanel>
                                    <TextBlock Text="Rebuild Icon Cache" FontWeight="SemiBold"/>
                                    <TextBlock Text="Fix broken or incorrect icons" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Results/Log -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <TextBlock Text="Task Status" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBox Grid.Row="1" x:Name="StatusLog" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="200" FontFamily="Consolas" BorderThickness="0" Background="Transparent"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
