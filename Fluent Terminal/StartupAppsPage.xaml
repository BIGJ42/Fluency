<Page
    x:Class="Fluent_Terminal.StartupAppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16" Padding="0">
        <TextBlock Text="Startup Apps Manager" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

        <InfoBar Grid.Row="1" Title="Startup Management" Message="Manage applications that run at startup to improve boot performance. Use the toggles to enable/disable apps." IsOpen="True" Severity="Informational" Margin="0,0,0,12" IsClosable="False"/>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,0,0,12">
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock x:Name="AppCountText" Text="Loading startup applications..." Style="{ThemeResource BodyTextBlockStyle}"/>
                <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Height="2" Visibility="Visible"/>
            </StackPanel>
            <Button x:Name="RefreshButton" Content="🔄 Refresh" Click="Refresh_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>

        <Border Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <ListView x:Name="StartupList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16,12" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
                                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AppName}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding AppPath}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                    <TextBlock Text="{Binding Source}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" IsOn="{Binding IsEnabled, Mode=TwoWay}" Toggled="OnAppToggled" Tag="{Binding}" MinWidth="60"/>
                                <Button Grid.Column="2" Content="🗑️ Remove" Click="RemoveApp_Click" Tag="{Binding}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        </Grid>
    </ScrollViewer>
</Page>
