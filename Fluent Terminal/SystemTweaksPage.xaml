<Page
    x:Class="Fluent_Terminal.SystemTweaksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Padding="0,0,0,24">
            <TextBlock Text="System Tweaks" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <InfoBar Title="System Optimization" Message="Apply various tweaks to optimize Windows 11 performance and features. Changes may require administrator rights." IsOpen="True" Severity="Informational" IsClosable="False"/>

            <!-- Performance Tweaks Section -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="⚡ Performance Tweaks" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Disable Visual Effects" FontWeight="SemiBold"/>
                            <TextBlock Text="Reduce animations and visual effects for better performance" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="DisableVisualEffects_Click" VerticalAlignment="Center" Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Disable Animations" FontWeight="SemiBold"/>
                            <TextBlock Text="Disable window animations for faster interface" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="DisableAnimations_Click" VerticalAlignment="Center" Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Disable Transparency Effects" FontWeight="SemiBold"/>
                            <TextBlock Text="Remove transparency effects for better performance" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="DisableTransparency_Click" VerticalAlignment="Center" Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Privacy & Security Section -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="🔒 Privacy &amp; Security" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Disable Activity History" FontWeight="SemiBold"/>
                            <TextBlock Text="Prevent Windows from tracking your activity" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="DisableActivityHistory_Click" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Disable Game Bar" FontWeight="SemiBold"/>
                            <TextBlock Text="Disable Game Bar overlay for better gaming performance" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="DisableGameBar_Click" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Disable Cloud Sync" FontWeight="SemiBold"/>
                            <TextBlock Text="Disable Windows sync with cloud accounts" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="DisableCloudSync_Click" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Context Menu Section -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="📋 Context Menu" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Restore Classic Context Menu" FontWeight="SemiBold"/>
                            <TextBlock Text="Use Windows 10-style context menu" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="⚙️ Apply" Click="RestoreContextMenu_Click" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Warning Banner -->
            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="12" Padding="16" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE814;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Admin Rights Required" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Some tweaks require administrator rights. Run the application as Administrator for full functionality. Always create a system restore point before applying changes." TextWrapping="WrapWholeWords" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
