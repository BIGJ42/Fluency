<Page
    x:Class="Fluent_Terminal.TerminalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowSpacing="16" RowDefinitions="Auto,Auto,*,Auto,Auto">
        <!-- Header and Controls -->
        <StackPanel Spacing="12" Padding="0,0,0,8">
            <TextBlock Text="Interactive Terminal" Style="{ThemeResource TitleTextBlockStyle}"/>
            <Grid ColumnDefinitions="200,Auto,Auto,Auto,1*,Auto" ColumnSpacing="12">
                <ComboBox x:Name="ShellSelector" Grid.Column="0" SelectedIndex="0" Header="Select Shell" CornerRadius="8">
                    <ComboBoxItem Content="PowerShell 7"/>
                    <ComboBoxItem Content="PowerShell 5"/>
                    <ComboBoxItem Content="Command Prompt"/>
                    <ComboBoxItem Content="Windows Terminal"/>
                </ComboBox>
                <Button Grid.Column="1" x:Name="StartButton" Content="▶ Start Session" Click="Start_Click" Style="{ThemeResource AccentButtonStyle}" VerticalAlignment="Bottom"/>
                <Button Grid.Column="2" x:Name="ClearButton" Content="🗑️ Clear" Click="Clear_Click" VerticalAlignment="Bottom"/>
                <Button Grid.Column="3" x:Name="CopyButton" Content="📋 Copy All" Click="Copy_Click" VerticalAlignment="Bottom"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                    <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemFillColorCautionBrush}" x:Name="StatusIndicator"/>
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="1" x:Name="ProgressRing" IsIndeterminate="True" Visibility="Collapsed" Height="2" Margin="0,0,0,8"/>

        <!-- Terminal Output -->
        <Border Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="16" MinHeight="350" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,8,0,8">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <FontIcon Glyph="&#xE756;" FontSize="14"/>
                    <TextBlock Text="Output Console" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Name="LineCountText" Text="Lines: 0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,0" HorizontalAlignment="Right"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" x:Name="TerminalScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TerminalOutput" 
                               FontFamily="Cascadia Code, Consolas" 
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                               TextWrapping="Wrap" 
                               LineHeight="18"
                               FontSize="12"
                               Margin="0,0,12,0"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Command History (Optional) -->
        <ComboBox Grid.Row="3" x:Name="CommandHistory" Header="Recent Commands" Margin="0,0,0,12" IsEditable="False"/>

        <!-- Command Input -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBox x:Name="InputBox" Grid.Column="0" PlaceholderText="Type command and press Enter..." 
                     KeyDown="InputBox_KeyDown" FontFamily="Cascadia Code, Consolas" AcceptsReturn="False" CornerRadius="8"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="⬅️ Send" Click="Send_Click" Style="{ThemeResource AccentButtonStyle}" Width="100" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Page>