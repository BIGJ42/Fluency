<Page
    x:Class="Fluent_Terminal.WslPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="16" Padding="0,0,0,24">
            <StackPanel Spacing="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xECAA;" FontSize="28" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="WSL Management" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <ProgressBar Grid.Row="1" x:Name="LoadingProgress" IsIndeterminate="True" Visibility="Collapsed" Height="2" Margin="0,0,0,8"/>

            <InfoBar Grid.Row="2" x:Name="WslStatus" Title="Checking WSL..." IsOpen="True" Severity="Informational" Margin="0,0,0,12" IsClosable="False"/>

            <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,0,0,12">
                <Button Content="Install WSL" Click="InstallWSL_Click" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}"/>
                <Button Grid.Column="1" Content="List Online Distros" Click="ListDistros_Click" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="2" Content="Refresh" Click="Refresh_Click" HorizontalAlignment="Stretch"/>
            </Grid>

            <StackPanel Grid.Row="4" Spacing="16">
                <TextBlock Text="Installed Distributions" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" MinHeight="150">
                    <ListView x:Name="DistroList" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,16" CornerRadius="8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding}" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="Remove" Click="RemoveDistro_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>